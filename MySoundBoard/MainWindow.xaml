<ui:FluentWindow x:Class="MySoundBoard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="680" Width="900"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" x:Name="Soundboard" Title="My Soundboard"/>

        <!-- Menu bar + Stop All button -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Menu Grid.Column="0">
                <ui:MenuItem Header="_File">
                    <ui:MenuItem Header="_Save" Icon="{ui:SymbolIcon Symbol=Save24}" Click="SaveMenuItem_Click"/>
                    <ui:MenuItem Header="_Load" x:Name="LoadMenuItem" Icon="{ui:SymbolIcon Symbol=ArrowDownload24}"/>
                </ui:MenuItem>
                <ui:MenuItem Header="_Tools">
                    <ui:MenuItem Header="Sort" Icon="{ui:SymbolIcon Symbol=ArrowSort24}" Click="SortMenuItem_Click"/>
                    <Separator/>
                    <ui:MenuItem Header="_Theme" Icon="{ui:SymbolIcon Symbol=List24}">
                        <ui:MenuItem x:Name="DayMenuItem" Icon="{ui:SymbolIcon Symbol=WeatherSunny24}" Header="_Light" IsCheckable="True" Click="DayMenuItem_Click"/>
                        <ui:MenuItem x:Name="NightMenuItem" Icon="{ui:SymbolIcon Symbol=DarkTheme24}" Header="_Dark" IsCheckable="True" IsChecked="True" Click="NightMenuItem_Click"/>
                    </ui:MenuItem>
                </ui:MenuItem>
            </Menu>
            <ui:Button Grid.Column="2"
                       Content="Stop All" Appearance="Danger"
                       Icon="{ui:SymbolIcon Symbol=Stop24}"
                       Margin="4,2" Padding="8,4"
                       ToolTip="Stop all playing sounds (Escape)"
                       Click="StopAllButton_Click"/>
        </Grid>

        <!-- Board title -->
        <ui:TextBox Grid.Row="2" x:Name="SoundBoardTitle" FontSize="24" Text="My Soundboard" BorderBrush="Transparent"/>

        <!-- Search / filter bar -->
        <ui:TextBox Grid.Row="3" x:Name="SearchBox"
                    Margin="4,0,4,4"
                    PlaceholderText="Search sounds…"
                    Icon="{ui:SymbolIcon Symbol=Search24}"
                    TextChanged="SearchBox_TextChanged"/>

        <!-- Sound button grid -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="SoundBoardGrid" Margin="4">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Global volume -->
        <Slider x:Name="VolumeSlider" Margin="10,0" Grid.Row="5"
                Maximum="100" Minimum="0"
                TickPlacement="BottomRight" TickFrequency="5" IsSnapToTickEnabled="True"
                ValueChanged="VolumeSlider_ValueChanged"/>

        <!-- Device selectors -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="5,0">
                <ui:TextBlock Margin="0,5">Primary Output</ui:TextBlock>
                <ComboBox x:Name="OutputDevice" ToolTip="Primary audio output — plays on your speakers or headset"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="5,0">
                <ui:TextBlock Margin="0,5">Secondary Output (mic routing)</ui:TextBlock>
                <ComboBox x:Name="HeadphoneDevice" ToolTip="Secondary output for mic routing (e.g. VB-Audio Cable Input)"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
